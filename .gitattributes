# Default behavior: auto-detect, but force LF (Linux style) in the repository
* text=auto eol=lf

# Windows scripts
*.bat text eol=crlf

# Linux scripts (must always be LF, otherwise they can fail in Docker)
*.sh text eol=lf

# Text-based images (SVG fix!)
*.svg text eol=lf

# Binary files (Git should not normalize these)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary