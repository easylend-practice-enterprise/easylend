sequenceDiagram
    actor User as User
    participant App as Kiosk App (Flutter)
    participant API as FastAPI Backend
    participant DB as PostgreSQL
    participant VB as Vision Box (RPi 4)
    participant AI as YOLO26 AI Service (VM2)
    participant Redis as Redis Cache

    User->>App: Selects asset from catalog
    App->>API: POST /api/v1/loans/checkout {aztec_code} [JWT, Idempotency-Key]

    API->>Redis: EXISTS idempotency:{key}
    alt Duplicate Idempotency-Key
        API-->>App: 409 Conflict {"Request already processing"}
    else Key not seen
        API->>Redis: SETEX idempotency:{key} 86400 "processing"

        API->>DB: BEGIN transaction
        API->>DB: SELECT asset BY aztec_code FOR UPDATE NOWAIT

        alt Asset row lock contention
            API-->>App: 409 Conflict {"Asset is currently being processed"}
            App-->>User: "Item is currently being processed"
        else Asset loaded
            alt Asset missing/deleted/not available/no locker
                API-->>App: 400 Bad Request
            else Asset valid
                API->>DB: SELECT locker BY locker_id FOR UPDATE NOWAIT

                alt Locker row lock contention
                    API-->>App: 409 Conflict {"Locker is currently being processed"}
                else Locker missing
                    API-->>App: 404 Not Found
                else Locker valid
                    API->>VB: Check WSS connection for kiosk

                    alt Vision Box offline
                        API-->>App: 503 Service Unavailable (Hardware offline)
                        App-->>User: "Locker currently out of service"
                    else Vision Box online
                        API->>DB: INSERT INTO loans {loan_status: 'RESERVED'}
                        API->>DB: UPDATE assets SET asset_status = 'BORROWED', locker_id = NULL
                        API->>DB: UPDATE lockers SET locker_status = 'AVAILABLE' (if occupied)

                        Note over API,VB: open_slot is sent before DB commit
                        Note over API,VB: locker_id in WSS payload = logical_number (physical slot int, e.g. 2), not the UUID
                        API->>VB: WSS: open_slot {locker_id: logical_number, loan_id}

                        alt Hardware command failed
                            API->>DB: ROLLBACK
                            API-->>App: 503 Service Unavailable
                        else Hardware command accepted
                            API->>DB: COMMIT
                            API-->>App: 202 Accepted {loan_id, checkout_locker_id, status: RESERVED}
                            App-->>User: Show loader: "Go to locker #N"
                        end
                    end
                end
            end
        end

        VB->>VB: GPIO: open slot + LED green

        User->>VB: Takes item from locker, closes door
        VB->>API: WSS: slot_closed event

        Note over VB,AI: Background check: locker must be empty
        VB->>API: POST /api/v1/vision/analyze (M2M) {loan_id, image, type: CHECKOUT}
        par Object Detection
            API->>AI: POST /detect {image}
            AI-->>API: {locker_empty, detections}
        and Segmentation
            API->>AI: POST /segment {image}
            AI-->>API: {has_damage_detected}
        end

        alt Locker not empty (Fraud/Error: item not taken)
            API->>DB: UPDATE loans SET loan_status = 'FRAUD_SUSPECTED' WHERE loan_id = ?
            API->>DB: UPDATE assets SET asset_status = 'AVAILABLE' WHERE asset_id = ?
            API->>DB: UPDATE lockers SET locker_status = 'AVAILABLE' WHERE locker_id = ?
            Note over API,VB: locker_id in WSS payload = logical_number (physical slot int), not the UUID
            API->>VB: WSS: set_led {locker_id: logical_number, color: red}
        else Locker empty (Success)
            Note over API,DB: Only update locker if it was OCCUPIED; guards against double-assignment masking bugs
            API->>DB: UPDATE lockers SET locker_status = 'AVAILABLE' WHERE locker_id = ? (only if status == OCCUPIED)
            API->>DB: UPDATE loans SET loan_status = 'ACTIVE' WHERE loan_id = ?
            Note over API,VB: locker_id in WSS payload = logical_number (physical slot int), not the UUID
            API->>VB: WSS: set_led {locker_id: logical_number, color: green}
        end

        Note over App,API: App polls the API every 3 sec for a status update (Polling)
        App->>API: GET /api/v1/loans/{loan_id}/status
        
        alt Status is FRAUD_SUSPECTED
            API-->>App: 200 OK {status: FRAUD_SUSPECTED}
            App-->>User: "Error detected. Item not taken."
        else Status is ACTIVE
            API-->>App: 200 OK {status: ACTIVE}
            App-->>User: "Good luck! Return the item on time."
        end
    end