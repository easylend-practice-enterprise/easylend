# EasyLend local environment template
# Copy this file to .env (root) and to backend/api/.env as needed for local development.
# Replace placeholder values with secure local secrets. DO NOT commit real secrets.

#########################
# Database (Postgres)
#########################
# Used by docker-compose and backend services
POSTGRES_USER=easylend
POSTGRES_PASSWORD=easylend_local_pass
POSTGRES_DB=easylend_db

#########################
# Redis
#########################
REDIS_PASSWORD=easylend_redis_pass

#########################
# App / Backend (api)
#########################
# Environment: dev | test | prod
ENVIRONMENT=dev

# JWT used by FastAPI for access tokens
JWT_SECRET_KEY=local_development_secret_key_change_me_later

# Database & Redis connection URLs (example local values)
# DATABASE_URL must match Postgres credentials above when running locally
DATABASE_URL=postgresql+asyncpg://easylend:easylend_local_pass@localhost:5432/easylend_db
REDIS_URL=redis://:easylend_redis_pass@localhost:6379/0

#########################
# Hardware & Simulation API Keys
#########################
# Used by kiosk hardware and simulation clients to authenticate
VISION_BOX_API_KEY=local-dev-vision-key-123
SIMULATION_API_KEY=local-dev-sim-key-123

#########################
# External Services (local overrides)
#########################
VISION_SERVICE_URL=http://localhost:8001
VISION_API_KEY=local-dev-vision-api-key-123
SIMULATION_SERVICE_URL=http://localhost:8002
VISIONBOX_WS_URL=ws://localhost:8000/ws/visionbox/kiosk_sim_1

#########################
# Optional / CI / Production placeholders
#########################
PGADMIN_DEFAULT_EMAIL=admin@easylend.com
PGADMIN_DEFAULT_PASSWORD=admin_123
SQLBAK_TOKEN=dummy
GHCR_USERNAME=dummy
GHCR_PAT=dummy
NTFY_WEBHOOK_URL=dummy
